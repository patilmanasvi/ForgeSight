# .env.example
# Copy this to .env and fill in your values

# API Configuration
REACT_APP_API_URL=https://api.forgesight.dev
REACT_APP_API_KEY=your_api_key_here

# Blockchain (Polygon)
REACT_APP_POLYGON_RPC=https://polygon-rpc.com
REACT_APP_POLYGON_CHAIN_ID=137

# Google Cloud
REACT_APP_GCP_PROJECT_ID=your_gcp_project_id
REACT_APP_VERTEX_AI_ENDPOINT=https://us-central1-aiplatform.googleapis.com

# Analytics
REACT_APP_GA_ID=your_google_analytics_id

# Feature Flags
REACT_APP_ENABLE_EXTENSION=true
REACT_APP_ENABLE_LIVE_ANALYSIS=true
REACT_APP_ENABLE_PROVENANCE=true
REACT_APP_ENABLE_AUDIT_LOG=true

# Environment
REACT_APP_ENVIRONMENT=development
REACT_APP_DEBUG=false
